{
	"name": "kyoichi-portfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "op run --env-file=.env.tpl -- vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "bun run build && wrangler pages deploy .svelte-kit/cloudflare",
		"cf:preview": "wrangler pages dev .svelte-kit/cloudflare"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.18",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"wrangler": "^3.0.0"
	},
	"dependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"fast-xml-parser": "^5.3.3",
		"marked": "^17.0.1"
	}
}
